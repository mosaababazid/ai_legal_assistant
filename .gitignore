# RAG / Project-specific heavy artifacts
# --------------------------------



# Persisted vector index (rebuild via `backend/scripts/build_index.py`)
backend/data/index_store/
data/index_store/

# Law files / German law corpus (re-download via `backend/scripts/law_scraper.py`)
backend/data/raw_laws/
data/raw_laws/
**/raw_laws/

# Uploaded/scanned documents (privacy-sensitive user data)
scanned_docs/


