# Node / Next.js frontend
# --------------------------------



# Dependencies
node_modules/

# Build / output
dist/
build/
.next/
out/

# Next.js / Vercel / Turbo
.vercel/
.turbo/
*.tsbuildinfo

# Package managers / caches / logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.npm/
.npmrc
.yarn/
.pnp.*


