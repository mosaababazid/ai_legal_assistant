# Python / FastAPI backend
# --------------------------------



# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
venv/
.venv/
env/

# Testing / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/

# Local logs and temp output
logs/
temp/
tmp/


